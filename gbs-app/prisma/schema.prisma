generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model projects {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  location   String?   @db.VarChar(255)
  status     String?   @default("Ongoing") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  workers    workers[]
  attendance attendance[]
  expenses   expenses[]
}

model workers {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  nic        String    @unique @db.VarChar(20)
  phone      String    @db.VarChar(20)
  daily_rate Decimal   @db.Decimal(10, 2)
  project_id Int
  created_at DateTime  @default(now()) @db.Timestamp(6)
  projects   projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attendance attendance[]
}

model attendance {
  id         Int       @id @default(autoincrement())
  date       DateTime  @default(now()) @db.Timestamp(6)
  status     String    @db.VarChar(20) @default("Present")
  worker_id  Int
  project_id Int
  created_at DateTime  @default(now()) @db.Timestamp(6)
  
  // Relationships
  workers    workers   @relation(fields: [worker_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects   projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  // Unique constraint to prevent duplicate attendance for same worker on same day
  @@unique([worker_id, date])
}

model expenses {
  id         Int       @id @default(autoincrement())
  item_name  String    @db.VarChar(255)
  amount     Decimal   @db.Decimal(10, 2)
  category   String    @db.VarChar(50)
  date       DateTime  @default(now()) @db.Timestamp(6)
  project_id Int
  created_at DateTime  @default(now()) @db.Timestamp(6)
  
  // Relationships
  projects   projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}